# On2Code Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Backend API base URL — must include /api/v1
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# Docker Compose (internal):
# NEXT_PUBLIC_API_URL=http://backend:4000/api/v1

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# GitHub organization for student repo creation (used in vscode.dev links)
NEXT_PUBLIC_GITHUB_ORG=on2code-org
