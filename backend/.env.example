# On2Code Backend Environment Variables
# Copy this file to .env and fill in the values

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=4000

# ── DATABASE ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# If not set, backend falls back to in-memory mode (data is lost on restart)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/on2code?sslmode=disable

# ── SECURITY ──────────────────────────────────────────────────────────────────
# ⚠️  REQUIRED IN PRODUCTION — Generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (add your production domain here)
ALLOWED_ORIGIN=http://localhost:3000
